{
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "in": "header",
        "name": "X-API-Key",
        "type": "apiKey"
      }
    }
  },
  "info": {
    "description": "Coze-facing demo wrapper for counselor assistant workflows.",
    "title": "Counselor Assistant Coze Demo API",
    "version": "0.1.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/draft_template": {
      "post": {
        "operationId": "draft_template",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "custom_style": {
                    "type": "string"
                  },
                  "existing_content_policy": {
                    "default": "merge",
                    "enum": [
                      "merge",
                      "ask",
                      "replace",
                      "blank_only"
                    ],
                    "type": "string"
                  },
                  "raw_input": {
                    "type": "string"
                  },
                  "style": {
                    "default": "professional_concise",
                    "enum": [
                      "professional_concise",
                      "warm_clinical",
                      "institutional_record",
                      "supervision_summary",
                      "custom"
                    ],
                    "type": "string"
                  },
                  "template_base64": {
                    "description": "Base64-encoded .docx template content for deployed demos.",
                    "type": "string"
                  },
                  "template_filename": {
                    "description": "Original filename for template_base64. Defaults to template.docx.",
                    "type": "string"
                  },
                  "template_path": {
                    "description": "Server-local DOCX path. Use only for local testing or preloaded server templates.",
                    "type": "string"
                  }
                },
                "required": [
                  "raw_input"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "answer": {
                      "type": "string"
                    },
                    "artifacts": {
                      "items": {
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "path": {
                            "type": "string"
                          },
                          "type": {
                            "type": "string"
                          },
                          "url": {
                            "type": "string"
                          }
                        },
                        "type": "object"
                      },
                      "type": "array"
                    },
                    "report": {
                      "type": "object"
                    },
                    "run_dir": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Template fill result"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "summary": "Draft and fill a Word template from raw counselor material"
      }
    },
    "/run_workflow": {
      "post": {
        "operationId": "run_workflow",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "custom_output_style": {
                    "type": "string"
                  },
                  "input": {
                    "type": "string"
                  },
                  "output_style": {
                    "default": "professional_concise",
                    "enum": [
                      "default",
                      "professional_concise",
                      "warm_clinical",
                      "institutional_record",
                      "supervision_summary",
                      "custom"
                    ],
                    "type": "string"
                  },
                  "render_docx": {
                    "default": true,
                    "type": "boolean"
                  },
                  "workflow": {
                    "default": "W3",
                    "enum": [
                      "W1",
                      "W2",
                      "W3",
                      "W4",
                      "W5",
                      "W6"
                    ],
                    "type": "string"
                  }
                },
                "required": [
                  "input"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "answer": {
                      "type": "string"
                    },
                    "artifacts": {
                      "items": {
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "path": {
                            "type": "string"
                          },
                          "type": {
                            "type": "string"
                          },
                          "url": {
                            "type": "string"
                          }
                        },
                        "type": "object"
                      },
                      "type": "array"
                    },
                    "checks": {
                      "type": "object"
                    },
                    "run_dir": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "structured_output": {
                      "type": "object"
                    },
                    "workflow": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Workflow result"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "summary": "Run a counselor assistant workflow"
      }
    }
  },
  "servers": [
    {
      "url": "https://counselor-agent-coze-api.onrender.com/coze"
    }
  ]
}
