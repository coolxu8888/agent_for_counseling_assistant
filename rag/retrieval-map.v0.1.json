{
  "schema_version": "rag-retrieval-map.v0.1",
  "updated_at": "2026-05-30",
  "agent": "counselor-assistant-agent-v0.1",
  "principles": [
    "先根据用户意图确定 workflow，再检索对应 RAG 分区和 topic。",
    "高风险主题优先检索 ethics-risk。",
    "记录类任务优先检索 case-recording 和 session-notes。",
    "系统字段类任务优先检索 forms-fields。",
    "W1-W3 不检索 CBT、人本、精神动力、家庭系统等流派 chunk 来改变基础信息抓取结构；W4-W5 可按用户指定流派组织概念化或下一次会谈计划 prompt。",
    "检索结果只能辅助咨询师形成结构化输出，不替代诊断、风险分级、危机处置或机构流程。"
  ],
  "allowed_workflows": [
    "workflow_1_intake_form",
    "workflow_2_case_summary",
    "workflow_3_session_note",
    "workflow_4_case_conceptualization",
    "workflow_5_next_session_plan",
    "workflow_6_counseling_roadmap"
  ],
  "allowed_sections": [
    "ethics-risk",
    "case-recording",
    "session-notes",
    "intake-assessment",
    "forms-fields",
    "theory-frameworks",
    "next-session-planning",
    "roadmap-planning"
  ],
  "fallback": {
    "unclear_user_intent": {
      "action": "clarify_before_retrieval",
      "message": "你希望我把这些笔记整理成个案信息摘要，还是生成本次 session 的咨询记录？如果这是初访材料，我也可以基于它生成后续需要补充询问的信息表。"
    },
    "modality_specific_request_in_v0_1": {
      "action": "do_not_retrieve_modality_chunks",
      "message": "W1-W3 阶段先生成统一基础信息抓取结果。若用户明确要求 CBT、人本、精神动力、家庭系统或整合取向概念化，请改走 W4；若用户明确要求基于某一流派生成下一次会谈计划，请改走 W5。"
    }
  },
