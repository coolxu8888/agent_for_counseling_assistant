# Copy this file to .env and fill in your local DeepSeek key.
# .env is ignored by git and must not be committed.

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=120

# Shared secret used by Coze when calling the deployed demo API.
# In Coze plugin auth, set header X-API-Key to this same value.
COZE_DEMO_API_KEY=

# Local/web workbench login. Use non-demo values for public deployments.
WORKBENCH_USER=
WORKBENCH_PASSWORD=

# Optional pilot signup controls for the deployed Web MVP.
# Leave WORKBENCH_ALLOW_SIGNUP empty/false to keep signup disabled.
# Set WORKBENCH_SIGNUP_INVITE_CODE to require an invite code for workspace creation.
WORKBENCH_ALLOW_SIGNUP=
WORKBENCH_SIGNUP_INVITE_CODE=

# Optional hosted-workspace data controls.
# WORKBENCH_MAX_UPLOAD_BYTES defaults to 10485760 (10 MB) when unset.
# WORKBENCH_RETENTION_DAYS enables one-click pruning of uploads, saved runs, and audit activity older than the window.
WORKBENCH_MAX_UPLOAD_BYTES=
WORKBENCH_RETENTION_DAYS=
